{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/weather/:path*",
      "destination": "https://dataservice.accuweather.com*"
    }
  ],
  "headers": [
    {
      "source": "/api/weather/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Authorization, Content-Type"
        }
      ]
    }
  ]
}
